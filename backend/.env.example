# Copy this file to .env for local development
# .env is gitignored so it won't be committed
# Requires python-dotenv to auto-load locally (already in requirements.txt)
# On Render, set these in the dashboard instead of using a .env file
#
# Validation: app.py checks for all vars listed here at startup.
# required=False vars log INFO if absent; required=True vars log WARNING.
# Add new secrets to _ENV_VAR_MANIFEST in app.py when you introduce them.

# Port the Flask server listens on (optional, defaults to 5001 locally)
# required=False — Render injects this automatically in deployment
PORT=5001

# FLASK_ENV is ignored in Flask 2.3+. Use FLASK_DEBUG=1 for debug mode instead.
# required=False — debug mode is off by default
# FLASK_DEBUG=1
# Kept here for reference only.
FLASK_ENV=development
